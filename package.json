{
  "name": "hymnmania-pipeline",
  "version": "1.0.0",
  "description": "Automated hymn to psytrance/house pipeline",
  "main": "src/pipeline.ts",
  "dependencies": {
    "@tonejs/midi": "^2.0.28",
    "axios": "^1.6.0",
    "express": "^5.2.1",
    "glob": "^13.0.6",
    "playwright": "^1.61.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^29.5.5",
    "@types/node": "^20.8.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1"
  },
  "scripts": {
    "start": "ts-node src/pipeline.ts",
    "test": "jest",
    "build": "tsc",
    "server": "ts-node src/server.ts",
    "repo:sanitize": "ts-node scripts/repository_sanitizer.ts",
    "repo:sync": "ts-node scripts/track_repository_sync.ts",
    "sync": "npm run repo:sanitize && npm run repo:sync",
    "verify": "ts-node scripts/canary_run.ts",
    "reindex": "ts-node scripts/reindex_registry.ts",
    "verify-integrity": "ts-node scripts/verify_integrity.ts",
    "install-hooks": "ts-node scripts/install_git_hooks.ts",
    "deploy": "npm run sync && ts-node scripts/sync_remote.ts && ts-node scripts/publish_remote.ts",
    "publish:streaming": "ts-node scripts/publish_streaming.ts"
  }
}
